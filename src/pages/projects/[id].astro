---
import { projectData } from "../../mocks/data.ts";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  return projectData.map((project) => {
    return {
      params: {
        id: project.id.toString(),
      },
    };
  });
}

const { id } = Astro.params;
const project = projectData.find((project) => project.id === Number(id));
---

<Layout title={project?.title}>
  <main
    class="w-full min-h-screen bg-secondary-bg pt-24 pb-20 px-6 md:px-12 lg:px-24 flex flex-col gap-16 relative overflow-hidden"
  >
    <header
      class="relative z-10 flex flex-col lg:flex-row justify-between items-end gap-10"
    >
      <div class="w-full lg:w-2/3">
        <span
          class="font-nav text-[10px] md:text-xs uppercase tracking-[0.4em] text-text/40 mb-4 block"
          >Project Case Study // 0{project?.id}</span
        >
        <h1
          class="text-[12vw] lg:text-[8rem] font-title font-extrabold leading-[0.8] tracking-tighter text-text"
        >
          {project?.title.split(" ")[0]}
          <br />
          <span class="italic font-light ml-[5vw]"
            >{project?.title.split(" ")[1] || ""}</span
          >
        </h1>
      </div>

      <div
        class="w-full lg:w-1/3 flex flex-col gap-4 border-l border-main-border pl-6"
      >
        <p class="font-text text-xl md:text-2xl leading-tight text-pretty">
          {project?.desc}
        </p>
        <div class="flex flex-wrap gap-2">
          {
            project?.tags.map((tag) => (
              <span class="font-nav text-[9px] uppercase border border-main-border px-2 py-1 rounded-full">
                {tag}
              </span>
            ))
          }
        </div>
      </div>
    </header>

    <section class="w-full relative group">
      <div
        class="w-full aspect-video bg-main-border overflow-hidden rounded-sm shadow-2xl transition-transform duration-700 hover:scale-[1.01]"
      >
        {
          project?.yt ? (
            <iframe
              src={project?.yt.replace("watch?v=", "embed/")}
              class="w-full h-full grayscale hover:grayscale-0 transition-all duration-1000"
              allowfullscreen
              referrerpolicy="strict-origin-when-cross-origin"
              loading="lazy"
              title="Project Demo"
            />
          ) : (
            <h1>Project Demo</h1>
          )
        }
      </div>
      <p
        class="font-nav text-[10px] uppercase tracking-widest mt-4 text-right text-text/40"
      >
        Visual Representation // Project Demo
      </p>
    </section>

    <section class="flex flex-col gap-12 border-t border-main-border py-16">
      <header class="flex flex-col gap-2">
        <span
          class="font-nav text-[10px] uppercase tracking-[0.4em] text-text/40"
          >Technical Documentation</span
        >
        <h2 class="font-title italic text-5xl md:text-6xl text-text">
          Schemas & Logic
        </h2>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        {
          project?.schema1 && (
            <div class="group flex flex-col gap-5">
              <Image
                src={project.schema1}
                alt="Database Entity Relationship Diagram"
                class="w-full h-full object-contain rounded-bl-4xl rounded-tr-4xl"
              />

              <div class="flex justify-between items-baseline px-1">
                <h4 class="font-title text-2xl italic text-text/80">
                  01 // Entity Relationship
                </h4>
                <span class="font-nav text-[9px] uppercase tracking-widest text-text/30">
                  Relational Model
                </span>
              </div>
            </div>
          )
        }
        {
          project?.schema2 && (
            <div class="group flex flex-col gap-5">
              <Image
                src={project.schema2}
                alt="System Use Case Diagram"
                class="w-full h-full object-contain rounded-br-4xl rounded-tr-4xl"
              />
              <div class="flex justify-between items-baseline px-1">
                <h4 class="font-title text-2xl italic text-text/80">
                  02 // System Logic
                </h4>
                <span class="font-nav text-[9px] uppercase tracking-widest text-text/30">
                  Functional Workflow
                </span>
              </div>
            </div>
          )
        }
      </div>
    </section>
    <a href="/" class="flex items-center gap-2">
      <span class="font-nav text-[10px] uppercase tracking-widest text-text/40"
        >Back to Home</span
      >
    </a>
  </main>
</Layout>
