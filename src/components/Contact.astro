---
import { Image } from "astro:assets";
import { socialMediaData } from "../mocks/data.ts";
---

<article class="w-full min-h-1/4 flex justify-center items-center pt-5">
  <div class="h-full w-1/3 flex flex-col items-center justify-start">
    <h1
      class="text-2xl font-title font-bold tracking-wide underline underline-offset-4 mb-5"
    >
      Education
    </h1>
    <ul
      class="flex flex-col gap-2 items-start list-disc font-default text-pretty"
    >
      <li>Tecnicatura en desarrollo de software - Universidad de la Punta</li>
      <li>Bachiller en Economía y Administración</li>
    </ul>
  </div>
  <div class="h-full w-1/3 flex flex-col items-center justify-start">
    <h1
      class="text-2xl font-title font-bold tracking-wide underline underline-offset-4 mb-5"
    >
      Contact
    </h1>
    <ul>
      {
        socialMediaData.map((item) => (
          <li class="flex gap-5">
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex gap-2"
            >
              <Image src={item.icon} alt={item.name} />
              {item.name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</article>
