---
import Image from "astro/components/Image.astro";

const { title, src, desc, tags, to } = Astro.props;
---

<a
  href={to}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex flex-col w-sm h-full bg-transparent border border-main-border rounded-b-sm transition-all duration-300 hover:shadow-sm hover:transform hover:scale-102 hover:-translate-y-2 hover:z-10"
>
  <div class="w-full h-full flex flex-col items-center">
    <header
      class="w-full h-2/3 border-b border-main-border overflow-hidden bg-main-border"
    >
      <Image
        src={src}
        alt={`Miniatura de ${title}`}
        class={"w-full h-full object-cover object-center grayscale group-hover:grayscale-0 transition-all duration-700 ease-in-out"}
      />
    </header>

    <main class="w-full flex flex-col items-center p-4 min-h-1/5 gap-1">
      <h1 class="text-xl font-bold font-title tracking-tight text-text italic">
        {title}
      </h1>
      <p
        class="text-sm font-text text-center text-text/80 leading-tight line-clamp-2"
      >
        {desc}
      </p>
    </main>

    <footer class="w-full mt-auto pb-4">
      <ul
        class="w-full flex flex-row flex-wrap items-center justify-center gap-2 px-2"
      >
        {
          tags.map((item: string) => (
            <li class="px-2 py-0.5 border border-main-border rounded-full text-[10px] uppercase font-nav text-text/60 tracking-tighter">
              {item}
            </li>
          ))
        }
      </ul>
    </footer>
  </div>
</a>
