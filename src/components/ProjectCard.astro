---
import Image from "astro/components/Image.astro";
const { title, src, desc, tags, to, id } = Astro.props;

let target = "_blank";
let rel = "noopener noreferrer";

if (id == 1 || id == 2) {
  target = "";
  rel = "";
}
---

<a
  href={to}
  target={target}
  rel={rel}
  class="group flex flex-col w-full bg-transparent border border-main-border rounded-b-sm transition-all duration-300 hover:shadow-sm md:hover:scale-102 md:hover:-translate-y-2 hover:z-10"
>
  <div class="w-full h-full flex flex-col">
    <header
      class="w-full aspect-video border-b border-main-border overflow-hidden bg-main-border"
    >
      <Image
        src={src}
        alt={`Miniatura de ${title}`}
        class="w-full h-full object-cover object-center grayscale group-hover:grayscale-0 transition-all duration-700 ease-in-out"
      />
    </header>

    <main class="w-full flex flex-col items-center p-5 gap-2">
      <h1
        class="text-lg md:text-xl font-bold font-title tracking-tight text-text italic text-center"
      >
        {title}
      </h1>
      <p
        class="text-xs md:text-sm font-text text-center text-text/80 leading-snug line-clamp-3"
      >
        {desc}
      </p>
    </main>

    <footer class="w-full mt-auto pb-5">
      <ul
        class="w-full flex flex-row flex-wrap items-center justify-center gap-2 px-4"
      >
        {
          tags.map((item: string) => (
            <li class="px-2 py-0.5 border border-main-border rounded-full text-[9px] md:text-[10px] uppercase font-nav text-text/60 tracking-tighter">
              {item}
            </li>
          ))
        }
      </ul>
    </footer>
  </div>
</a>
