---
import { Image } from "astro:assets";
import Arrow from "../assets/icons/arrow-narrow-down.svg";
---

<main
  class="w-full min-h-screen flex flex-col items-center bg-secondary-bg relative"
  id="index"
>
  <header
    class="w-full h-auto min-h-15 flex flex-col md:flex-row items-center justify-between px-5 py-4 md:py-0 border-b border-main-border bg-secondary-bg/80 fixed top-0 z-50 backdrop-blur-md gap-4 md:gap-0"
  >
    <div class="hidden xs:block">
      <h1 class="font-text text-lg md:text-xl font-bold tracking-wide">
        Tadeo Wotoszyn
      </h1>
    </div>

    <nav class="font-nav">
      <ul class="flex gap-2 xxs:gap-3 text-[10px] xs:text-xs sm:text-sm">
        <li>
          <a href="#index" class="relative py-1 group"
            >INDEX
            <span
              class="absolute bottom-0 left-0 w-0 h-px bg-text transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
        </li>
        <p class="opacity-30">/</p>
        <li>
          <a href="#about" class="relative py-1 group"
            >ABOUT
            <span
              class="absolute bottom-0 left-0 w-0 h-px bg-text transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
        </li>
        <p class="opacity-30">/</p>
        <li>
          <a href="#projects" class="relative py-1 group"
            >PROJECTS
            <span
              class="absolute bottom-0 left-0 w-0 h-px bg-text transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
        </li>
        <p class="opacity-30">/</p>
        <li>
          <a href="#contact" class="relative py-1 group"
            >CONTACT
            <span
              class="absolute bottom-0 left-0 w-0 h-px bg-text transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
        </li>
      </ul>
    </nav>

    <div class="hidden lg:block">
      <h2 class="font-text text-sm xl:text-xl font-bold tracking-wide">
        tadeo.woto@gmail.com
      </h2>
    </div>
  </header>

  <div
    class="w-full h-screen pt-20 md:pt-10 flex flex-col justify-between items-center p-4 md:p-2"
  >
    <div class="grow flex items-start justify-center pt-5">
      <h1
        class="text-center font-title font-extrabold leading-none tracking-tighter
        text-[15vw]
        xs:text-[12vw]
        md:text-[8rem]
        lg:text-[10rem]"
      >
        Tadeo Wotoszyn
      </h1>
    </div>

    <div
      class="w-full flex flex-col xs:flex-row items-center xs:items-end justify-between gap-6 xs:gap-0 pb-10"
    >
      <div
        class="text-base md:text-lg font-text font-extrabold tracking-wide text-center xs:text-left"
      >
        <p>WEB DEVELOPER</p>
        <p>WELCOME TO MY PORFOLIO</p>
      </div>

      <div class="flex font-default items-center gap-2">
        <p class="text-xs md:text-base">SCROLL DOWN</p>
        <div class="animate-bounce">
          <Image src={Arrow} alt="down arrow" class="w-5 md:w-6" />
        </div>
      </div>
    </div>
  </div>
</main>
