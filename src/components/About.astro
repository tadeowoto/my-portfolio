---
import PersonalInfo from "./PersonalInfo.astro";
import { socialMediaData, skillsData } from "../mocks/data.ts";
import Image from "astro/components/Image.astro";
---

<section
  class="w-full max-h-screen min-h-screen pt-10 h-screen flex flex-col items-start justify-center bg-secondary-bg border-t border-main-border p-2"
  id="about"
>
  <PersonalInfo />
  <article class="w-full min-h-1/4 flex justify-center items-center pt-5">
    <div class="h-full w-1/3 flex flex-col items-center justify-start">
      <h1
        class="text-2xl font-title font-bold tracking-wide underline underline-offset-4 mb-5"
      >
        Education
      </h1>
      <ul
        class="flex flex-col gap-2 items-start list-disc font-default text-pretty"
      >
        <li>Tecnicatura en desarrollo de software - Universidad de la Punta</li>
        <li>Bachiller en Economía y Administración</li>
      </ul>
    </div>
    <div class="h-full w-1/3 flex flex-col items-center justify-start">
      <h1
        class="text-2xl font-title font-bold tracking-wide underline underline-offset-4 mb-5"
      >
        Contact
      </h1>
      <ul>
        {
          socialMediaData.map((item) => (
            <li class="flex gap-5">
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex gap-2"
              >
                <Image src={item.icon} alt={item.name} />
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </article>
  <div class="h-full w-full flex flex-col items-center justify-start">
    <h1
      class="text-2xl font-title font-bold tracking-wide underline underline-offset-4 mb-5"
    >
      Skills
    </h1>
    <ul
      class="grid grid-cols-2 md:grid-cols-3 gap-x-10 gap-y-6 font-mono text-sm tracking-wide mb-5"
    >
      {
        skillsData.map((item) => (
          <li class="flex items-center gap-3 group">
            <Image
              src={item.icon}
              alt={item.name}
              class="w-4 h-4 opacity-70 group-hover:opacity-100 transition"
            />
            <p class="text-neutral-800">{item.name}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
