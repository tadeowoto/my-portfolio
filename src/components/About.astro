---
import PersonalInfo from "./PersonalInfo.astro";
import Contact from "./Contact.astro";
import Skills from "./Skills.astro";
---

<section
  class="w-full min-h-screen py-20 lg:py-32 flex flex-col items-center justify-center bg-secondary-bg border-t border-main-border px-6 md:px-10"
  id="about"
>
  <div class="max-w-6xl w-full flex flex-col gap-16 md:gap-24">
    <PersonalInfo />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
      <div class="flex flex-col md:items-center">
        <h1
          class="text-2xl font-title font-bold tracking-wide underline underline-offset-4 mb-8"
        >
          Education
        </h1>
        <ul class="flex flex-col gap-4 list-disc font-default pl-5">
          <li>
            Tecnicatura en desarrollo de software - Universidad de la Punta
          </li>
          <li>Bachiller en Economía y Administración</li>
        </ul>
      </div>

      <Contact />
    </div>

    <Skills />
  </div>
</section>
