>
  <PersonalInfo />
  <article
    class="w-full min-h-1/4 bg-amber-500 flex justify-center items-center pt-5"
  >
    <div class="h-full w-1/3 flex flex-col items-center justify-start">
      <h1 class="text-2xl">Education</h1>
      <ul class="flex flex-col gap-2 items-start list-disc">
        <li>Tecnicatura en desarrollo de software - Universidad de la Punta</li>
        <li>Bachiller en Economía y Administración</li>
      </ul>
    </div>
    <div class="h-full w-1/3 flex flex-col items-center justify-start">
      <h1>Contact</h1>
      <ul>
        <li><a href="">Linkedin</a></li>
        <li><a href="">Github</a></li>
        <li><a href="">Email</a></li>
      </ul>
    </div>
    <div class="h-full w-1/3 flex flex-col items-center justify-start">
      <h1>Skills</h1>
      <ul>
        <li>dasdas</li>
      </ul>
    </div>
  </article>
  <div class="w-full min-h-1/4 bg-amber-800">
    <h1>Projects</h1>
  </div>
</section>
