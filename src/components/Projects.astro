---
import ProjectCard from "./ProjectCard.astro";
import { projectData } from "../mocks/data";
---

<section
  class="w-full max-h-screen min-h-screen pt-10 h-screen flex flex-col items-start justify-center bg-secondary-bg border-t border-main-border p-2"
  id="projects"
>
  <h1
    class="text-2xl font-title font-bold tracking-wide underline underline-offset-4 mb-5"
  >
    Projects
  </h1>
  <article class="flex items-center justify-center gap-2 w-full h-4/5">
    {
      projectData.map((item) => (
        <ProjectCard
          title={item.title}
          src={item.src}
          desc={item.desc}
          tags={item.tags}
          to={item.to}
        />
      ))
    }
  </article>
</section>
